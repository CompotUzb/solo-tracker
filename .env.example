# Copy to .env and fill real Discord values before connecting the bot.
# These placeholders are intentionally fake and safe to commit.
DISCORD_TOKEN=replace_with_discord_bot_token
DISCORD_CLIENT_ID=replace_with_discord_client_id
TRACKED_GUILD_ID=replace_with_discord_guild_id

# Legacy/simple whitelist. The named *_CHANNEL_ID values below are merged into the
# tracked set automatically, so you can leave this as a single placeholder if you
# only use the named channels.
TRACKED_CHANNEL_IDS=replace_with_channel_id_1,replace_with_channel_id_2

# Named channels. Tracked input channels map Discord activity to player stats; the
# command channel is reserved for bot commands; system-output receives notifications.
# Leave any of these blank to disable that channel. No IDs are hardcoded in source.
COMMANDS_CHANNEL_ID=replace_with_commands_channel_id
DAILY_QUESTS_CHANNEL_ID=replace_with_daily_quests_channel_id
MIND_TRAINING_CHANNEL_ID=replace_with_mind_training_channel_id
BODY_TRAINING_CHANNEL_ID=replace_with_body_training_channel_id
WORK_SKILL_CHANNEL_ID=replace_with_work_skill_channel_id

# Where the bot posts system notifications (level up, achievements, summaries...).
# If blank, the app runs in dashboard-only notification mode (still healthy).
SYSTEM_OUTPUT_CHANNEL_ID=replace_with_system_output_channel_id

DATABASE_PATH=./data/solo-system.sqlite
API_HOST=127.0.0.1
API_PORT=3333
STORE_MESSAGE_CONTENT=false
CONTENT_MAX_CHARS=0
TIMEZONE=Asia/Tashkent
DAILY_QUEST_CREATE_TIME=06:00
DAILY_EVALUATION_TIME=00:00
# Development/test only. Production ignores this value.
# DAILY_QUEST_TIER_OVERRIDE=1

# Optional AI support. MVP scope: Main Quest draft generation only.
AI_MAIN_QUEST_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

SKIP_DISCORD_LOGIN=true
