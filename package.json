{
  "name": "solo-system-tracker",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "pnpm --filter @solo-system/server dev",
    "dev:web": "pnpm --filter @solo-system/web dev",
    "build": "pnpm -r --sort build",
    "start": "pnpm --filter @solo-system/server start",
    "migrate": "pnpm --filter @solo-system/server migrate",
    "app": "pnpm --filter @solo-system/server app",
    "reset:local-data": "pnpm --filter @solo-system/server app reset-local-data",
    "test": "pnpm --filter @solo-system/shared build && pnpm -r test",
    "lint": "pnpm --filter @solo-system/shared build && pnpm -r lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
